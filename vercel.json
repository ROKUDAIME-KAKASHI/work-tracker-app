{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/reminders",
            "schedule": "0 10 * * *"
        },
        {
            "path": "/api/cron/reminders",
            "schedule": "0 16 * * *"
        },
        {
            "path": "/api/cron/reminders",
            "schedule": "30 16 * * *"
        },
        {
            "path": "/api/cron/reminders",
            "schedule": "30 17 * * *"
        }
    ]
}
